# Production overrides for Tauri macOS builds.
# Credentials (VITE_WRIKE_CLIENT_ID, VITE_WRIKE_CLIENT_SECRET) must be kept in
# your local .env file, which is gitignored and never committed.

# Tauri v2 serves the app at https://tauri.localhost in production.
# Register this URI in the Wrike Developer Portal as an allowed Redirect URI.
VITE_WRIKE_REDIRECT_URI=https://tauri.localhost/oauth/callback
