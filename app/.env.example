# Wrike OAuth App credentials
# Get these from: https://www.wrike.com/frontend/apps/index.html
VITE_WRIKE_CLIENT_ID=
VITE_WRIKE_CLIENT_SECRET=
VITE_WRIKE_REDIRECT_URI=http://localhost:5173/oauth/callback

# Optional: Wrike Permanent Token (skips OAuth — useful for dev/internal use)
# Get it from: Wrike → Profile → Apps & Integrations → API Apps → Create Token
VITE_WRIKE_PERMANENT_TOKEN=
